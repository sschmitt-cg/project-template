{
  "detection": {
    "description": "Python project with virtualenv",
    "indicators": ["venv/", ".venv/", "pyproject.toml", "requirements.txt", "setup.py"]
  },
  "permissions": {
    "allow": [
      "Bash(\"{{PROJECT_PATH}}/venv/bin/python\" *)",
      "Bash(\"{{PROJECT_PATH}}/venv/bin/python3\" *)",
      "Bash(\"{{PROJECT_PATH}}/venv/bin/pip\" *)",
      "Bash(\"{{PROJECT_PATH}}/venv/bin/pytest\" *)",
      "Bash(\"{{PROJECT_PATH}}/venv/bin/ruff\" *)",
      "Bash(\"{{PROJECT_PATH}}/venv/bin/mypy\" *)",
      "Bash(\"{{PROJECT_PATH}}/venv/bin/playwright\" *)",
      "Bash(\"{{PROJECT_PATH}}/.venv/bin/python\" *)",
      "Bash(\"{{PROJECT_PATH}}/.venv/bin/python3\" *)",
      "Bash(\"{{PROJECT_PATH}}/.venv/bin/pip\" *)",
      "Bash(\"{{PROJECT_PATH}}/.venv/bin/pytest\" *)",
      "Bash(\"{{PROJECT_PATH}}/.venv/bin/ruff\" *)",
      "Bash(\"{{PROJECT_PATH}}/.venv/bin/mypy\" *)",
      "Bash(\"{{PROJECT_PATH}}/.venv/bin/playwright\" *)"
    ]
  }
}
