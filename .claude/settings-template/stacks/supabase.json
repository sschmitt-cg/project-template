{
  "detection": {
    "description": "Supabase project",
    "indicators": ["supabase/"],
    "packageJson": ["@supabase/supabase-js", "@supabase/ssr"],
    "envVars": ["SUPABASE_"]
  },
  "permissions": {
    "allow": [
      "mcp__supabase__get_project_url",
      "mcp__supabase__get_publishable_keys",
      "Bash(npx supabase *)"
    ]
  }
}
