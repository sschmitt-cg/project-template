      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(gh api repos/sschmitt-cg/project-template/*)",
      "Bash(npm --version)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm run * 2>&1 | head *)",
      "Bash(npm info *)",
      "Bash(npm audit *)",
      "Bash(npx tsc *)",
      "Bash(npx eslint *)",
      "Bash(npx prettier *)",
