      "Bash(pnpm create *)",
      "Bash(pnpm approve-builds *)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm lint *)",
      "Bash(claude mcp list)",
      "Bash(claude mcp get *)",
      "Bash(npx skills *)",
      "Bash(rm */.git/HEAD.lock)",
      "Bash(rm */.git/index.lock)",
      "Bash(python3 -m py_compile *)",
      "Bash(python -m py_compile *)",
      "Bash(python3 -m pytest *)",
      "Bash(python -m pytest *)",
      "Bash(python3 -m mypy *)",
      "Bash(python3 -m ruff *)",
      "Bash(pip install *)",
      "Bash(pip3 install *)",
      "Bash(whois *)",
      "Bash(dig *)",
      "WebSearch(*)",
      "WebFetch(*)",
      "Read(/Users/scottschmitt/Documents/Scottsidian/Projects/**)",
      "Write(/Users/scottschmitt/Documents/Scottsidian/Projects/**)",
      "Edit(/Users/scottschmitt/Documents/Scottsidian/Projects/**)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty' 2>/dev/null); case \"$cmd\" in \"git commit\"* | \"git -C \"*) if echo \"$cmd\" | grep -q ' commit'; then if echo \"$cmd\" | grep -q '^git -C '; then if echo \"$cmd\" | grep -q '^git -C \"'; then repo_path=$(echo \"$cmd\" | sed 's/^git -C \"\\([^\"]*\\)\".*/\\1/'); else repo_path=$(echo \"$cmd\" | awk '{print $3}'); fi; branch=$(git -C \"$repo_path\" branch --show-current 2>/dev/null); else branch=$(git branch --show-current 2>/dev/null); fi; if [ \"$branch\" = \"main\" ] || [ \"$branch\" = \"dev\" ]; then echo \"Blocked: refusing to commit directly to $branch. Switch to a feature branch first.\" >&2; exit 2; fi; fi ;; esac",
            "statusMessage": "Checking branch before commit..."
          }
        ]
      }
    ]
  }
}
