{
  "permissions": {
    "allow": [
      "Bash(git status)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git push *)",
      "Bash(git pull *)",
      "Bash(git fetch *)",
      "Bash(git checkout *)",
      "Bash(git log *)",
      "Bash(git diff *)",
      "Bash(git remote *)",
      "Bash(git branch *)",
      "Bash(git stash *)",
      "Bash(git log * | head *)",
      "Bash(git branch * | grep *)",
      "Bash(find * | grep *)",
      "Bash(find * | head *)",
      "Bash(gh auth *)",
      "Bash(gh repo *)",
      "Bash(gh pr create *)",
      "Bash(gh pr view *)",
      "Bash(gh pr list *)",
      "Bash(gh pr diff *)",
      "Bash(gh pr checks *)",
      "Bash(gh pr status *)",
      "Bash(gh issue *)",
      "Bash(gh run *)",
      "Bash(npm --version)",
      "Bash(npm install *)",
      "Bash(npm run *)",
      "Bash(npm test *)",
      "Bash(npm run * 2>&1 | head *)",
      "Bash(npx tsc *)",
      "Bash(pnpm --version)",
      "Bash(pnpm install *)",
      "Bash(pnpm create *)",
      "Bash(pnpm approve-builds *)",
      "Bash(pnpm typecheck *)",
      "Bash(pnpm lint *)",
      "Bash(git -C * status)",
      "Bash(git -C * fetch *)",
      "Bash(git -C * diff *)",
      "Bash(git -C * log *)",
      "Bash(git -C * show *)",
      "Bash(git -C * remote *)",
      "Bash(git -C * branch *)",
      "Bash(gh api repos/sschmitt-cg/project-template/*)",
      "Bash(claude mcp list)",
      "Bash(claude mcp get *)",
      "Bash(npx skills *)",
      "Bash(mkdir -p *)",
      "Bash(find /Users/scottschmitt/.claude -name \"sync-template*\" 2>/dev/null)",
      "Read(//Users/scottschmitt/.claude/**)"
    ],
    "additionalDirectories": [
      "/Users/scottschmitt/.claude/commands"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "cmd=$(jq -r '.tool_input.command // empty' 2>/dev/null); case \"$cmd\" in \"git commit\"*) branch=$(git branch --show-current 2>/dev/null); if [ \"$branch\" = \"main\" ]; then echo \"Blocked: refusing to commit directly to main. Switch to a feature branch first.\" >&2; exit 2; fi ;; esac",
            "statusMessage": "Checking branch before commit..."
          }
        ]
      }
    ]
  }
}
